---
/**
 * HubChip — fixed-position link back to briefing-hub.
 * Rendered top-right on every page via BaseLayout.
 *
 * Hub URL can be overridden via PUBLIC_HUB_URL env var at build time
 * (lets us migrate to a custom domain later without code changes).
 */
const hubUrl =
  import.meta.env.PUBLIC_HUB_URL ?? "https://lowtidebuild.github.io/briefing-hub/";
---
<a class="hub-chip" href={hubUrl} aria-label="Briefing Hub로 이동">
  ← BRIEFING HUB
</a>

<style>
  .hub-chip {
    position: fixed;
    top: 16px;
    right: 16px;
    padding: 6px 12px;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 11px;
    letter-spacing: 1.5px;
    text-decoration: none;
    background: #1a1a1a;
    color: #fafaf8;
    border: 1px solid #1a1a1a;
    z-index: 100;
    transition: background 0.15s, color 0.15s;
  }
  .hub-chip:hover {
    background: #fafaf8;
    color: #1a1a1a;
  }
</style>
