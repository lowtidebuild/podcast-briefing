---
import QuoteBlock from './QuoteBlock.astro';

interface KeyPoint {
  heading: string;
  body: string;
}

interface Quote {
  text: string;
  attribution: string;
}

interface GroundedQuote {
  source_text_en: string;
  translation_ko: string;
  speaker: string;
  attribution: string;
  is_verbatim: boolean;
  translation_is_verbatim: boolean;
  source_char_start: number | null;
  source_char_end: number | null;
  match_score: number;
}

interface Guest {
  name: string;
  title: string;
}

interface Props {
  slug: string;
  podcast: string;
  category: string;
  title: string;
  published: string;
  link: string;
  podcastUrl: string;
  guest: Guest | null;
  summaryKo: string;
  summaryEn: string;
  keyPointsKo: KeyPoint[];
  keyPointsEn: KeyPoint[];
  quoteKo: Quote;
  quoteEn: Quote;
  groundedQuote?: GroundedQuote | null;
  keywordsKo: string[];
  keywordsEn: string[];
  hasTranscript: boolean;
  transcriptUrl: string;
}

const {
  slug,
  podcast,
  category,
  title,
  published,
  link,
  podcastUrl,
  guest,
  summaryKo,
  summaryEn,
  keyPointsKo,
  keyPointsEn,
  quoteKo,
  quoteEn,
  groundedQuote,
  keywordsKo,
  keywordsEn,
  hasTranscript,
  transcriptUrl,
} = Astro.props;

const dateStr = new Date(published).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const episodeId = `ep-${slug.replace(/[^\w-]/g, '-')}`;

const downloadTitle = `${published.slice(0, 10)}-${podcast.toLowerCase().replace(/\s+/g, '-')}.md`;
---

<article
  class="episode"
  data-category={category}
  data-slug={slug}
  data-podcast={podcast}
  data-title={title}
  data-published-date={published.slice(0, 10)}
  data-guest-name={guest?.name || ''}
  data-guest-title={guest?.title || ''}
>
  <div class="episode-category">{category}</div>
  <h2 class="episode-title">{title}</h2>
  <div class="episode-meta">
    {podcastUrl ? (
      <a href={podcastUrl} target="_blank" rel="noopener" class="podcast-link">{podcast}</a>
    ) : (
      <span>{podcast}</span>
    )}
    <span> · {dateStr}</span>
  </div>

  {guest && (
    <div class="episode-guest">
      with <strong>{guest.name}</strong> — <em>{guest.title}</em>
    </div>
  )}

  <!-- Summary -->
  {summaryKo || summaryEn ? (
    <>
      <div class="episode-summary" data-lang="ko">
        {(summaryKo || summaryEn).split('\n\n').filter(Boolean).map(para => (
          <p>{para}</p>
        ))}
      </div>
      <div class="episode-summary" data-lang="en">
        {(summaryEn || summaryKo).split('\n\n').filter(Boolean).map(para => (
          <p>{para}</p>
        ))}
      </div>
    </>
  ) : (
    <div class="episode-pending">
      Summary available at next pipeline run.
    </div>
  )}

  <!-- Key Points -->
  {keyPointsKo.length > 0 && (
    <div class="key-points" data-lang="ko">
      {keyPointsKo.map((point) => (
        <div>
          <h3>{point.heading}</h3>
          {point.body.split('\n\n').filter(Boolean).map(para => (
            <p>{para}</p>
          ))}
        </div>
      ))}
    </div>
  )}
  {keyPointsEn.length > 0 && (
    <div class="key-points" data-lang="en">
      {keyPointsEn.map((point) => (
        <div>
          <h3>{point.heading}</h3>
          {point.body.split('\n\n').filter(Boolean).map(para => (
            <p>{para}</p>
          ))}
        </div>
      ))}
    </div>
  )}

  <!-- Quote -->
  <QuoteBlock quoteKo={quoteKo} quoteEn={quoteEn} groundedQuote={groundedQuote || null} />

  <!-- Keywords -->
  <div class="keywords" data-lang="ko">
    {keywordsKo.map((kw) => (
      <span class="keyword-pill">{kw}</span>
    ))}
  </div>
  <div class="keywords" data-lang="en">
    {keywordsEn.map((kw) => (
      <span class="keyword-pill">{kw}</span>
    ))}
  </div>

  <!-- Action Bar -->
  <div class="action-bar">
    {link && (
      <a href={link} target="_blank" rel="noopener" class="action-item">Listen to episode →</a>
    )}
    {hasTranscript && (
      <>
        <span class="separator">·</span>
        <button class="action-item action-btn" data-copy-id={episodeId} data-transcript-url={transcriptUrl}>Copy transcript</button>
        <span class="separator">·</span>
        <button class="action-item action-btn" data-download-id={episodeId} data-transcript-url={transcriptUrl} data-download-title={downloadTitle}>Download .md</button>
      </>
    )}
  </div>
</article>

<script>
  const transcriptCache = new Map<string, string>();

  async function fetchTranscript(url: string) {
    if (transcriptCache.has(url)) return transcriptCache.get(url) || '';
    const response = await fetch(url);
    if (!response.ok) throw new Error(`Transcript fetch failed: ${response.status}`);
    const text = await response.text();
    transcriptCache.set(url, text);
    return text;
  }

  function yamlString(value: string) {
    return JSON.stringify(value || '');
  }

  function setTemporaryLabel(btn: Element, label: string, original: string | null) {
    btn.textContent = label;
    setTimeout(() => { btn.textContent = original; }, 2000);
  }

  function paragraphText(root: Element, selector: string) {
    return Array.from(root.querySelectorAll(selector))
      .map((el) => el.textContent?.trim())
      .filter(Boolean)
      .join('\n\n');
  }

  function keyPointsMarkdown(root: Element, lang: string) {
    return Array.from(root.querySelectorAll(`.key-points[data-lang="${lang}"] > div`))
      .map((item) => {
        const heading = item.querySelector('h3')?.textContent?.trim();
        const body = paragraphText(item, 'p');
        if (!heading && !body) return '';
        return heading ? `### ${heading}\n\n${body}` : body;
      })
      .filter(Boolean)
      .join('\n\n');
  }

  function quoteMarkdown(root: Element, lang: string) {
    const quote = root.querySelector(`[data-lang="${lang}"] .quote-block`);
    const text = quote?.querySelector('p')?.textContent?.trim();
    const attribution = quote
      ?.querySelector('.quote-attribution')
      ?.textContent
      ?.replace(/^—\s*/, '')
      .trim();
    if (!text) return '';
    return attribution ? `> ${text}\n>\n> — ${attribution}` : `> ${text}`;
  }

  function keywordsMarkdown(root: Element, lang: string) {
    return Array.from(root.querySelectorAll(`.keywords[data-lang="${lang}"] .keyword-pill`))
      .map((pill) => pill.textContent?.trim())
      .filter(Boolean)
      .map((keyword) => `- ${keyword}`)
      .join('\n');
  }

  function buildMarkdown(article: HTMLElement, transcript: string) {
    const {
      slug = '',
      podcast = '',
      title = '',
      category = '',
      publishedDate = '',
      guestName = '',
      guestTitle = '',
    } = article.dataset;

    const summaryKo = paragraphText(article, '.episode-summary[data-lang="ko"] p');
    const summaryEn = paragraphText(article, '.episode-summary[data-lang="en"] p');
    const keyPointsKo = keyPointsMarkdown(article, 'ko');
    const keyPointsEn = keyPointsMarkdown(article, 'en');
    const quoteKo = quoteMarkdown(article, 'ko');
    const quoteEn = quoteMarkdown(article, 'en');
    const keywordsKo = keywordsMarkdown(article, 'ko');
    const keywordsEn = keywordsMarkdown(article, 'en');

    return `---
podcast: ${yamlString(podcast)}
title: ${yamlString(title)}
date: ${publishedDate}
category: ${yamlString(category)}
slug: ${yamlString(slug)}
${guestName ? `guest: ${yamlString(guestName)}` : ''}
---

# ${title}
> **${podcast}** | ${category} | ${publishedDate}
${guestName ? `> with ${guestName}${guestTitle ? ` — ${guestTitle}` : ''}` : ''}

## Briefing

### Korean

${summaryKo}

### English

${summaryEn}

## Key Points

### Korean

${keyPointsKo}

### English

${keyPointsEn}

## Quote

${quoteKo}

${quoteEn}

## Keywords

### Korean

${keywordsKo}

### English

${keywordsEn}

## Transcript

${transcript}`;
  }

  document.querySelectorAll('[data-copy-id]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const el = btn as HTMLElement;
      const transcriptUrl = el.dataset.transcriptUrl;
      if (!transcriptUrl) return;
      const original = btn.textContent;
      btn.textContent = 'Copying...';
      try {
        const text = await fetchTranscript(transcriptUrl);
        await navigator.clipboard.writeText(text);
        setTemporaryLabel(btn, 'Copied!', original);
      } catch {
        setTemporaryLabel(btn, 'Unavailable', original);
      }
    });
  });

  document.querySelectorAll('[data-download-id]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const el = btn as HTMLElement;
      const id = el.dataset.downloadId;
      const transcriptUrl = el.dataset.transcriptUrl;
      if (!id || !transcriptUrl) return;
      const article = el.closest('.episode') as HTMLElement | null;
      if (!article) return;
      const original = btn.textContent;
      btn.textContent = 'Preparing...';
      try {
        const transcript = await fetchTranscript(transcriptUrl);
        const md = buildMarkdown(article, transcript);
        const blob = new Blob([md], { type: 'text/markdown' });
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = el.dataset.downloadTitle || 'episode.md';
        a.click();
        URL.revokeObjectURL(a.href);
        setTemporaryLabel(btn, 'Downloaded', original);
      } catch {
        setTemporaryLabel(btn, 'Unavailable', original);
      }
    });
  });
</script>
