---
import EpisodeCard from './EpisodeCard.astro';

interface KeyPoint {
  heading: string;
  body: string;
}

interface Quote {
  text: string;
  attribution: string;
}

interface GroundedQuote {
  source_text_en: string;
  translation_ko: string;
  speaker: string;
  attribution: string;
  is_verbatim: boolean;
  translation_is_verbatim: boolean;
  source_char_start: number | null;
  source_char_end: number | null;
  match_score: number;
}

interface Guest {
  name: string;
  title: string;
}

interface Props {
  slug: string;
  podcast: string;
  category: string;
  title: string;
  published: string;
  link: string;
  podcastUrl: string;
  guest: Guest | null;
  summaryKo: string;
  summaryEn: string;
  keyPointsKo: KeyPoint[];
  keyPointsEn: KeyPoint[];
  quoteKo: Quote;
  quoteEn: Quote;
  groundedQuote?: GroundedQuote | null;
  keywordsKo: string[];
  keywordsEn: string[];
  hasTranscript: boolean;
  transcriptUrl: string;
}

const props = Astro.props;

const dateStr = new Date(props.published).toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
});
---

<details class="archive-episode" data-category={props.category}>
  <summary class="archive-episode-header">
    <span class="archive-podcast">{props.podcast}</span>
    <span class="archive-title">{props.title}</span>
    <span class="archive-date">{dateStr}</span>
  </summary>
  <div class="archive-episode-body">
    <EpisodeCard
      slug={props.slug}
      podcast={props.podcast}
      category={props.category}
      title={props.title}
      published={props.published}
      link={props.link}
      podcastUrl={props.podcastUrl}
      guest={props.guest}
      summaryKo={props.summaryKo}
      summaryEn={props.summaryEn}
      keyPointsKo={props.keyPointsKo}
      keyPointsEn={props.keyPointsEn}
      quoteKo={props.quoteKo}
      quoteEn={props.quoteEn}
      groundedQuote={props.groundedQuote || null}
      keywordsKo={props.keywordsKo}
      keywordsEn={props.keywordsEn}
      hasTranscript={props.hasTranscript}
      transcriptUrl={props.transcriptUrl}
    />
  </div>
</details>
