---
interface Props {
  quoteKo: { text: string; attribution: string };
  quoteEn: { text: string; attribution: string };
}

const { quoteKo, quoteEn } = Astro.props;
---

<div data-lang="ko">
  <blockquote class="quote-block">
    <p>{quoteKo.text}</p>
    <div class="quote-attribution">— {quoteKo.attribution}</div>
  </blockquote>
</div>
<div data-lang="en">
  <blockquote class="quote-block">
    <p>{quoteEn.text}</p>
    <div class="quote-attribution">— {quoteEn.attribution}</div>
  </blockquote>
</div>
