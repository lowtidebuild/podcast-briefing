---
import BaseLayout from '../layouts/BaseLayout.astro';
import LangToggle from '../components/LangToggle.astro';
import CategoryFilter from '../components/CategoryFilter.astro';
import '../styles/editorial.css';

import { readFileSync, readdirSync } from 'node:fs';
import { join } from 'node:path';

const dataDir = join(process.cwd(), '..', 'data', 'summaries');
const files = readdirSync(dataDir).filter(f => f.endsWith('.json') && f !== 'feed.json');
const episodeFiles = files.map(f => JSON.parse(readFileSync(join(dataDir, f), 'utf-8')));

interface Episode {
  slug: string;
  podcast: string;
  category: string;
  title: string;
  published: string;
  link: string;
  podcast_url?: string;
}

const episodes: Episode[] = episodeFiles
  .filter((ep: any) => ep.slug)
  .sort((a: any, b: any) => new Date(b.published).getTime() - new Date(a.published).getTime());

// Group by week (Monday start)
function getWeekStart(dateStr: string): string {
  const d = new Date(dateStr);
  const day = d.getUTCDay();
  const diff = d.getUTCDate() - day + (day === 0 ? -6 : 1); // Monday
  const monday = new Date(d);
  monday.setUTCDate(diff);
  return monday.toISOString().slice(0, 10);
}

const grouped = new Map<string, Episode[]>();
episodes.forEach(ep => {
  const week = getWeekStart(ep.published);
  if (!grouped.has(week)) grouped.set(week, []);
  grouped.get(week)!.push(ep);
});

const categories = [...new Set(episodes.map(ep => ep.category))];

function formatWeekHeader(mondayStr: string): string {
  const d = new Date(mondayStr + 'T00:00:00Z');
  return `Week of ${d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' })}`;
}

function formatShortDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}
---

<BaseLayout title="Archive — Podcast Briefing" description="All podcast briefings, organized by week">
  <header class="site-header">
    <div class="archive-back">
      <a href={`${import.meta.env.BASE_URL}`}>← Latest briefings</a>
    </div>
    <h1 class="site-title">Archive</h1>
    <div class="site-subtitle">{episodes.length} briefings from {[...grouped.keys()].length} weeks</div>
    <div class="header-nav">
      <span></span>
      <LangToggle />
    </div>
  </header>

  <CategoryFilter categories={categories} />

  <main>
    {[...grouped.entries()].map(([weekStart, eps], i) => (
      <div>
        <h2 class={`archive-week-header ${i === 0 ? 'first' : ''}`}>{formatWeekHeader(weekStart)}</h2>
        <ul class="archive-list">
          {eps.map(ep => (
            <li class="archive-item" data-category={ep.category}>
              <span class="archive-podcast">{ep.podcast}</span>
              <span class="archive-title">
                {ep.link ? (
                  <a href={ep.link} target="_blank" rel="noopener">{ep.title}</a>
                ) : (
                  <span>{ep.title}</span>
                )}
              </span>
              <span class="archive-date">{formatShortDate(ep.published)}</span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </main>

  <footer class="site-footer">
    Auto-generated by Podcast Briefing Pipeline · Updated Mon/Wed/Fri at 15:00 KST<br />
    10 sources · AI-curated · KO/EN bilingual
  </footer>
</BaseLayout>
