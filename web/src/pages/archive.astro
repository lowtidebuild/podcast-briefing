---
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryFilter from '../components/CategoryFilter.astro';
import LangToggle from '../components/LangToggle.astro';
import ArchiveEpisode from '../components/ArchiveEpisode.astro';
import '../styles/editorial.css';
import { loadEpisodes, loadTranscriptSlugSet } from '../lib/episodes';
import type { Episode } from '../lib/episodes';

const episodes: Episode[] = loadEpisodes();
const transcriptSlugs = loadTranscriptSlugSet();
const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const transcriptUrl = (slug: string) => `${basePath}data/transcripts/${slug}.txt`;

// Group by week (Monday start)
function getWeekStart(dateStr: string): string {
  const d = new Date(dateStr);
  const day = d.getUTCDay();
  const diff = d.getUTCDate() - day + (day === 0 ? -6 : 1); // Monday
  const monday = new Date(d);
  monday.setUTCDate(diff);
  return monday.toISOString().slice(0, 10);
}

const grouped = new Map<string, Episode[]>();
episodes.forEach(ep => {
  const week = getWeekStart(ep.published);
  if (!grouped.has(week)) grouped.set(week, []);
  grouped.get(week)!.push(ep);
});

const categories = [...new Set(episodes.map(ep => ep.category))];

function formatWeekHeader(mondayStr: string): string {
  const d = new Date(mondayStr + 'T00:00:00Z');
  return `Week of ${d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' })}`;
}
---

<BaseLayout title="Archive — Podcast Briefing" description="All podcast briefings, organized by week">
  <header class="site-header">
    <div class="archive-back">
      <a href={`${import.meta.env.BASE_URL}`}>← Latest briefings</a>
    </div>
    <h1 class="site-title">Archive</h1>
    <div class="site-subtitle">{episodes.length} briefings from {[...grouped.keys()].length} weeks</div>
    <div class="header-nav">
      <span><LangToggle /></span>
    </div>
  </header>

  <CategoryFilter categories={categories} />

  <main>
    {[...grouped.entries()].map(([weekStart, eps], i) => (
      <div>
        <h2 class={`archive-week-header ${i === 0 ? 'first' : ''}`}>{formatWeekHeader(weekStart)}</h2>
        {eps.map(ep => (
          <ArchiveEpisode
            slug={ep.slug}
            podcast={ep.podcast}
            category={ep.category}
            title={ep.title}
            published={ep.published}
            link={ep.link || ''}
            podcastUrl={ep.podcast_url || ''}
            guest={ep.guest || null}
            summaryKo={ep.summary_ko}
            summaryEn={ep.summary_en}
            keyPointsKo={ep.key_points_ko}
            keyPointsEn={ep.key_points_en}
            quoteKo={ep.notable_quote_ko}
            quoteEn={ep.notable_quote_en}
            groundedQuote={ep.notable_quote || null}
            keywordsKo={ep.keywords_ko}
            keywordsEn={ep.keywords_en}
            hasTranscript={transcriptSlugs.has(ep.slug)}
            transcriptUrl={transcriptUrl(ep.slug)}
          />
        ))}
      </div>
    ))}
  </main>

  <footer class="site-footer">
    Updated Mon/Thu at 15:00 KST · 10 sources · KO/EN bilingual
    <div class="site-credit">By <a href="https://github.com/lowtidebuild" target="_blank" rel="noopener">lowtidebuild</a>, powered by <a href="https://claude.com/product/claude-code" target="_blank" rel="noopener">Claude Code</a></div>
  </footer>
</BaseLayout>
