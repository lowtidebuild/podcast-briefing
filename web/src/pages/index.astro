---
import BaseLayout from '../layouts/BaseLayout.astro';
import EpisodeCard from '../components/EpisodeCard.astro';
import LangToggle from '../components/LangToggle.astro';
import CategoryFilter from '../components/CategoryFilter.astro';
import '../styles/editorial.css';
import { loadEpisodes, loadTranscriptSlugSet } from '../lib/episodes';
import type { Episode } from '../lib/episodes';

const allEpisodes: Episode[] = loadEpisodes();
const transcriptSlugs = loadTranscriptSlugSet();
const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const transcriptUrl = (slug: string) => `${basePath}data/transcripts/${slug}.txt`;

// Main page: only last 7 days
const sevenDaysAgo = new Date();
sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);
const episodes = allEpisodes.filter(
  ep => new Date(ep.published) >= sevenDaysAgo
);

// Fallback: if no episodes in last 7 days, show latest 5
const displayEpisodes = episodes.length > 0 ? episodes : allEpisodes.slice(0, 5);

// Group episodes by date
const grouped = new Map<string, Episode[]>();
displayEpisodes.forEach(ep => {
  const date = ep.published.slice(0, 10);
  if (!grouped.has(date)) grouped.set(date, []);
  grouped.get(date)!.push(ep);
});

const hasArchive = allEpisodes.length > displayEpisodes.length;

// Extract unique categories for filter
const categories = [...new Set(displayEpisodes.map((ep) => ep.category))];

// Format today's date
const today = new Date().toLocaleDateString('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const latestTitle = episodes[0]?.title || 'AI-curated podcast intelligence';

// Sources data for disclosure
const sources = [
  { name: 'Odd Lots', org: 'Bloomberg', category: 'Macro / Markets', freq: '2-3x/week', url: 'https://www.bloomberg.com/oddlots' },
  { name: 'Dwarkesh Podcast', org: '', category: 'AI / Tech Deep Dive', freq: 'Biweekly', url: 'https://www.dwarkeshpatel.com' },
  { name: 'Lex Fridman Podcast', org: '', category: 'AI / Tech Deep Dive', freq: 'Biweekly', url: 'https://lexfridman.com/podcast' },
  { name: 'Fareed Zakaria GPS', org: 'CNN', category: 'Politics / Geopolitics', freq: 'Weekly', url: 'https://www.cnn.com/shows/fareed-zakaria-gps' },
  { name: 'Hard Fork', org: 'NYT', category: 'Tech / AI Current Affairs', freq: 'Weekly', url: 'https://www.nytimes.com/column/hard-fork' },
  { name: 'a16z Podcast', org: '', category: 'Tech / AI Current Affairs', freq: '2-3x/week', url: 'https://a16z.com/podcasts' },
  { name: 'Ezra Klein Show', org: 'NYT', category: 'Politics / Geopolitics', freq: '1-2x/week', url: 'https://www.nytimes.com/column/ezra-klein-podcast' },
  { name: 'All-In Podcast', org: '', category: 'Tech × Politics × Economics', freq: '1-2x/week', url: 'https://www.allinpodcast.co' },
  { name: 'Exponential View', org: '', category: 'Tech × Politics × Economics', freq: 'Weekly', url: 'https://www.exponentialview.co' },
  { name: 'Making Sense', org: 'Sam Harris', category: 'Philosophy / AI Ethics', freq: 'Biweekly', url: 'https://www.samharris.org/podcasts' },
];

function formatDateHeader(dateStr: string): string {
  const d = new Date(dateStr + 'T00:00:00Z');
  return d.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
}
---

<BaseLayout title="Podcast Briefing" description={`Latest: ${latestTitle} — AI-curated bilingual intelligence from 10 podcast sources`}>
  <header class="site-header">
    <h1 class="site-title">Podcast Briefing</h1>
    <div class="site-subtitle">AI-curated intelligence from 10 sources</div>
    <details class="sources-disclosure">
      <summary>10 Sources ▾</summary>
      <ul class="sources-list">
        {sources.map(s => (
          <li>
            <a href={s.url} target="_blank" rel="noopener">{s.name}{s.org ? ` (${s.org})` : ''}</a>
            <span class="source-meta">{s.category} · {s.freq}</span>
          </li>
        ))}
      </ul>
    </details>
    <div class="header-nav">
      <span>{today} · <LangToggle /></span>
      <div class="header-nav-right">
        {hasArchive && <a href={`${import.meta.env.BASE_URL}/archive/`} class="header-archive-link">Archive →</a>}
      </div>
    </div>
  </header>

  <CategoryFilter categories={categories} />

  <main>
    {[...grouped.entries()].map(([date, eps], i) => (
      <div>
        <h2 class={`date-header ${i === 0 ? 'first' : ''}`}>{formatDateHeader(date)}</h2>
        {eps.map((ep) => (
          <EpisodeCard
            slug={ep.slug}
            podcast={ep.podcast}
            category={ep.category}
            title={ep.title}
            published={ep.published}
            link={ep.link || ''}
            podcastUrl={ep.podcast_url || ''}
            guest={ep.guest || null}
            summaryKo={ep.summary_ko}
            summaryEn={ep.summary_en}
            keyPointsKo={ep.key_points_ko}
            keyPointsEn={ep.key_points_en}
            quoteKo={ep.notable_quote_ko}
            quoteEn={ep.notable_quote_en}
            groundedQuote={ep.notable_quote || null}
            keywordsKo={ep.keywords_ko}
            keywordsEn={ep.keywords_en}
            hasTranscript={transcriptSlugs.has(ep.slug)}
            transcriptUrl={transcriptUrl(ep.slug)}
          />
        ))}
      </div>
    ))}
  </main>

  <footer class="site-footer">
    Updated Mon/Thu at 15:00 KST · 10 sources · KO/EN bilingual
    <div class="site-credit">By <a href="https://github.com/lowtidebuild" target="_blank" rel="noopener">lowtidebuild</a>, powered by <a href="https://claude.com/product/claude-code" target="_blank" rel="noopener">Claude Code</a></div>
  </footer>
</BaseLayout>
