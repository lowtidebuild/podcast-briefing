---
import BaseLayout from '../layouts/BaseLayout.astro';
import EpisodeCard from '../components/EpisodeCard.astro';
import LangToggle from '../components/LangToggle.astro';
import CategoryFilter from '../components/CategoryFilter.astro';
import '../styles/editorial.css';

// Load all episode JSON files at build time (path relative to repo root via Vite alias)
import { readFileSync, readdirSync } from 'node:fs';
import { join } from 'node:path';

const dataDir = join(process.cwd(), '..', 'data', 'summaries');
const files = readdirSync(dataDir).filter(f => f.endsWith('.json') && f !== 'feed.json');
const episodeFiles = files.map(f => JSON.parse(readFileSync(join(dataDir, f), 'utf-8')));

interface Episode {
  slug: string;
  podcast: string;
  category: string;
  title: string;
  published: string;
  summary_ko: string;
  summary_en: string;
  key_points_ko: { heading: string; body: string }[];
  key_points_en: { heading: string; body: string }[];
  notable_quote_ko: { text: string; attribution: string };
  notable_quote_en: { text: string; attribution: string };
  keywords_ko: string[];
  keywords_en: string[];
}

// Sort episodes by date (newest first)
const episodes: Episode[] = episodeFiles
  .filter((ep: any) => ep.slug)
  .sort((a: any, b: any) => new Date(b.published).getTime() - new Date(a.published).getTime())
  .slice(0, 50);

// Extract unique categories for filter
const categories = [...new Set(episodes.map((ep) => ep.category))];

// Format today's date
const today = new Date().toLocaleDateString('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Latest episode for OG description
const latestTitle = episodes[0]?.title || 'AI-curated podcast intelligence';
---

<BaseLayout title="Podcast Briefing" description={`Latest: ${latestTitle} — AI-curated bilingual intelligence from 9 podcast sources`}>
  <header class="site-header">
    <h1 class="site-title">Podcast Briefing</h1>
    <div class="site-subtitle">AI-curated intelligence from 9 sources</div>
    <div class="header-nav">
      <span>{today}</span>
      <LangToggle />
    </div>
  </header>

  <CategoryFilter categories={categories} />

  <main>
    {episodes.map((ep) => (
      <EpisodeCard
        podcast={ep.podcast}
        category={ep.category}
        title={ep.title}
        published={ep.published}
        summaryKo={ep.summary_ko}
        summaryEn={ep.summary_en}
        keyPointsKo={ep.key_points_ko}
        keyPointsEn={ep.key_points_en}
        quoteKo={ep.notable_quote_ko}
        quoteEn={ep.notable_quote_en}
        keywordsKo={ep.keywords_ko}
        keywordsEn={ep.keywords_en}
      />
    ))}
  </main>

  <footer class="site-footer">
    Auto-generated by Podcast Briefing Pipeline · Updated daily at 15:00 KST<br />
    9 sources · AI-curated · KO/EN bilingual
  </footer>
</BaseLayout>
